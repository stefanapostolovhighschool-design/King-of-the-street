@model Team
@{ ViewData["Title"] = "Delete Team"; }
<div class="kos-container kos-narrow">
    <h1 class="kos-section-title">Delete Team</h1>
    <div class="kos-card kos-pad">
        <p class="kos-danger-note">⚠️ Are you sure you want to permanently delete this team?</p>
        <div class="kos-summary">
            <div><span>Name</span><strong>@Model.Name</strong></div>
            <div><span>Players</span><strong>@(Model.Players?.Count ?? 0)</strong></div>
            <div><span>Status</span><strong>@(Model.IsApproved ? "Approved" : "Pending")</strong></div>
        </div>
        <form asp-action="Delete" method="post" class="kos-mt">
            <input type="hidden" asp-for="Id" />
            <div class="kos-flex">
                <button type="submit" class="kos-btn kos-btn-danger">Yes, Delete</button>
                <a class="kos-btn kos-btn-outline" asp-action="Index">Cancel</a>
            </div>
        </form>
    </div>
</div>
