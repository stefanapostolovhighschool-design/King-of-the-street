@{ ViewData["Title"] = "About"; }
<div class="kos-container">
    <h1 class="kos-section-title">About King Of The Street</h1>
    <p class="kos-section-sub">The home of 3v3 street basketball.</p>
    <div class="kos-card"><div class="kos-card-body">
        <p>King Of The Street is a tournament management platform built for the 3v3 street basketball community. Players create teams, register for tournaments, and compete through knockout brackets while fans follow live scores, leaderboards, and MVP races.</p>
        <p>The platform also features a full <strong>match simulation engine</strong>: every player has realistic basketball attributes (shooting percentages and skill ratings), and matches are simulated possession-by-possession to produce realistic box scores, MVPs, and standings.</p>
        <p>Built with ASP.NET Core MVC, Entity Framework Core, ASP.NET Identity, a clean service layer, a Web API, AJAX, and unit tests.</p>
    </div></div>
</div>
