@page
@model LoginModel
@{ ViewData["Title"] = "Log In"; }
<div class="kos-container kos-narrow">
    <h1 class="kos-section-title">Log In</h1>
    <p class="kos-section-sub">Welcome back to the court.</p>

    <div class="kos-card kos-pad">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="kos-validation"></div>

            <div class="kos-field">
                <label asp-for="Input.Email" class="kos-label"></label>
                <input asp-for="Input.Email" class="kos-input" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="kos-error"></span>
            </div>

            <div class="kos-field">
                <label asp-for="Input.Password" class="kos-label"></label>
                <input asp-for="Input.Password" class="kos-input" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="kos-error"></span>
            </div>

            <label class="kos-checkbox">
                <input asp-for="Input.RememberMe" /> <span>Remember me</span>
            </label>

            <button type="submit" class="kos-btn kos-btn-primary kos-mt">Log In</button>
            <p class="kos-meta kos-mt">No account yet? <a asp-page="/Account/Register">Sign up</a></p>
        </form>
    </div>

    <div class="kos-card kos-pad kos-mt" style="background:#fff7f1">
        <p class="kos-meta" style="margin:0"><strong>Demo accounts</strong></p>
        <p class="kos-meta" style="margin:4px 0 0">Admin — admin@kingofthestreet.com / Admin123!</p>
        <p class="kos-meta" style="margin:0">Captain — captain@kingofthestreet.com / Captain123!</p>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
